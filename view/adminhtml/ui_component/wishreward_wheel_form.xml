<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">wishreward_wheel_form.wishreward_wheel_form_data_source</item>
            <item name="deps" xsi:type="string">wishreward_wheel_form.wishreward_wheel_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Wheel of Fortune</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="save">
                <url path="wishreward/wheel/save"/>
                <class>save primary</class>
                <label translate="true">Save Wheel</label>
            </button>
            <button name="back">
                <url path="wishreward/wheel/index"/>
                <class>back</class>
                <label translate="true">Back</label>
            </button>
            <button name="delete">
                <url path="wishreward/wheel/delete"/>
                <class>delete</class>
                <label translate="true">Delete</label>
            </button>
        </buttons>
        <namespace>wishreward_wheel_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>wishreward_wheel_form.wishreward_wheel_form_data_source</dep>
        </deps>
    </settings>

    <dataSource name="wishreward_wheel_form_data_source">
        <argument name="dataProvider" xsi:type="configurableObject">
            <argument name="class" xsi:type="string">Doroshko\WishReward\Model\Wheel\FormDataProvider</argument>
            <argument name="name" xsi:type="string">wishreward_wheel_form_data_source</argument>
            <argument name="primaryFieldName" xsi:type="string">wheel_id</argument>
            <argument name="requestFieldName" xsi:type="string">wheel_id</argument>
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="submit_url" xsi:type="url" path="wishreward/wheel/save"/>
                </item>
            </argument>
        </argument>
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
    </dataSource>

    <fieldset name="general" sortOrder="10">
        <settings>
            <label translate="true">General Settings</label>
        </settings>

        <field name="wheel_id" formElement="hidden">
            <settings>
                <dataScope>wheel_id</dataScope>
                <tooltip>
                    <description translate="true">Unique identifier for the wheel configuration. Hidden field, automatically managed by the system.</description>
                </tooltip>
            </settings>
        </field>

        <field name="title" formElement="input">
            <settings>
                <label translate="true">Title</label>
                <dataScope>title</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>

        <field name="is_active" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="number">1</item>
                    <item name="prefer" xsi:type="string">toggle</item>
                    <item name="valueMap" xsi:type="array">
                        <item name="true" xsi:type="string">1</item>
                        <item name="false" xsi:type="string">0</item>
                    </item>
                </item>
            </argument>
            <settings>
                <label translate="true">Is Active</label>
                <dataScope>is_active</dataScope>
                <dataType>boolean</dataType>
            </settings>
        </field>

        <field name="win_message" formElement="textarea">
            <settings>
                <label translate="true">Win Message</label>
                <dataScope>win_message</dataScope>
            </settings>
        </field>

        <field name="no_win_message" formElement="textarea">
            <settings>
                <label translate="true">No Win Message</label>
                <dataScope>no_win_message</dataScope>
            </settings>
        </field>

        <field name="attempts_per_user" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Attempts Per User</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="dataScope" xsi:type="string">attempts_per_user</item>
                    <item name="default" xsi:type="number">1</item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">true</item>
                        <item name="validate-digits" xsi:type="boolean">true</item>
                        <item name="validate-greater-than-zero" xsi:type="boolean">true</item>
                    </item>
                </item>
            </argument>
            <settings>
                <label translate="true">Attempts Per User</label>
                <dataScope>attempts_per_user</dataScope>
            </settings>
        </field>

        <field name="attempts_period_unit" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="default" xsi:type="string">day</item>
                    <item name="label" xsi:type="string" translate="true">Attempts Period</item>
                    <item name="formElement" xsi:type="string">select</item>
                    <item name="dataScope" xsi:type="string">attempts_period_unit</item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">true</item>
                    </item>
                    <item name="options" xsi:type="array">
                        <item name="day" xsi:type="array">
                            <item name="value" xsi:type="string">day</item>
                            <item name="label" xsi:type="string" translate="true">Day</item>
                        </item>
                        <item name="week" xsi:type="array">
                            <item name="value" xsi:type="string">week</item>
                            <item name="label" xsi:type="string" translate="true">Week</item>
                        </item>
                        <item name="month" xsi:type="array">
                            <item name="value" xsi:type="string">month</item>
                            <item name="label" xsi:type="string" translate="true">Month</item>
                        </item>
                        <item name="year" xsi:type="array">
                            <item name="value" xsi:type="string">year</item>
                            <item name="label" xsi:type="string" translate="true">Year</item>
                        </item>
                        <item name="forever" xsi:type="array">
                            <item name="value" xsi:type="string">forever</item>
                            <item name="label" xsi:type="string" translate="true">Forever</item>
                        </item>
                    </item>
                </item>
            </argument>
            <settings>
                <label translate="true">Attempts Period</label>
                <dataScope>attempts_period_unit</dataScope>
            </settings>
        </field>

        <field name="storeviews" formElement="multiselect" class="Magento\Store\Ui\Component\Form\Field\StoreView">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">block</item>
                    <item name="default" xsi:type="number">0</item>
                </item>
            </argument>
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>int</dataType>
                <label translate="true">Store View</label>
                <dataScope>storeviews</dataScope>
                <tooltip>
                    <description translate="true">Select store views where the wheel will be available. Required field.</description>
                </tooltip>
            </settings>
            <formElements>
                <multiselect>
                    <settings>
                        <options class="Magento\Cms\Ui\Component\Listing\Column\Cms\Options"/>
                    </settings>
                </multiselect>
            </formElements>
        </field>

        <field name="allowed_customer_groups" formElement="multiselect">
            <settings>
                <label translate="true">Allowed Customer Groups</label>
                <dataScope>allowed_customer_groups</dataScope>
                <dataType>text</dataType>
                <tooltip>
                    <description translate="true">Choose customer groups that can interact with the wheel (e.g., General, Wholesale).</description>
                </tooltip>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
            <formElements>
                <multiselect>
                    <settings>
                        <options class="Magento\Customer\Model\Customer\Source\GroupSourceInterface"/>
                    </settings>
                </multiselect>
            </formElements>
        </field>

        <field name="start_date" formElement="date">
            <settings>
                <validation>
                    <rule name="validate-date" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">From</label>
                <visible>true</visible>
                <dataScope>start_date</dataScope>
            </settings>
        </field>
        <field name="end_date" formElement="date">
            <settings>
                <validation>
                    <rule name="validate-date" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">To</label>
                <visible>true</visible>
                <dataScope>end_date</dataScope>
            </settings>
        </field>

        <field name="popup_theme">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Popup Theme</item>
                    <item name="formElement" xsi:type="string">select</item>
                    <item name="source" xsi:type="string">wheel</item>
                    <item name="dataScope" xsi:type="string">popup_theme</item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">true</item>
                    </item>
                    <item name="options" xsi:type="array">
                        <item name="0" xsi:type="array">
                            <item name="label" xsi:type="string" translate="true">Light</item>
                            <item name="value" xsi:type="string">light</item>
                        </item>
                        <item name="1" xsi:type="array">
                            <item name="label" xsi:type="string" translate="true">Dark</item>
                            <item name="value" xsi:type="string">dark</item>
                        </item>
                    </item>
                </item>
            </argument>
        </field>
    </fieldset>

    <fieldset name="wheel_configuration" sortOrder="20">
        <settings>
            <label translate="true">Wheel Configuration</label>
            <collapsible>true</collapsible>
        </settings>
        <field name="wheel_config" formElement="text">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="component" xsi:type="string">Doroshko_WishReward/js/wheel-config-visual</item>
                    <item name="componentType" xsi:type="string">field</item>
                    <item name="elementTmpl" xsi:type="string">Doroshko_WishReward/wheel-config-visual</item>
                    <item name="provider" xsi:type="string">wishreward_wheel_form.wishreward_wheel_form_data_source</item>
                    <item name="priceRuleOptions" xsi:type="object">Doroshko\WishReward\Model\Config\Source\CartPriceRules</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Wheel Configuration</label>
                <dataScope>wheel_config</dataScope>
                <dataType>text</dataType>
                <tooltip>
                    <description translate="true">
                    JSON configuration for the wheel's segments, prizes, and appearance.
                    </description>
                </tooltip>
            </settings>
        </field>
    </fieldset>

    <fieldset name="popup_settings" sortOrder="30">
        <settings>
            <label translate="true">Popup Settings</label>
            <collapsible>true</collapsible>
        </settings>

        <field name="popup_title" formElement="input">
            <settings>
                <label translate="true">Popup Title</label>
                <dataScope>popup_title</dataScope>
            </settings>
        </field>

        <field name="popup_description" formElement="textarea">
            <settings>
                <label translate="true">Popup Description</label>
                <dataScope>popup_description</dataScope>
            </settings>
        </field>

        <field name="popup_company_logo" formElement="imageUploader">
            <settings>
                <notice translate="true">Upload company logo</notice>
                <label translate="true">Company Logo</label>
                <componentType>imageUploader</componentType>
                <dataScope>popup_company_logo</dataScope>
            </settings>
            <formElements>
                <imageUploader>
                    <settings>
                        <allowedExtensions>jpg jpeg gif png webp</allowedExtensions>
                        <maxFileSize>2097152</maxFileSize>
                        <uploaderConfig>
                            <param xsi:type="string" name="url">wishreward/wheel/upload</param>
                        </uploaderConfig>
                    </settings>
                </imageUploader>
            </formElements>
        </field>

        <field name="popup_company_text" formElement="input">
            <settings>
                <label translate="true">Company Text</label>
                <dataScope>popup_company_text</dataScope>
            </settings>
        </field>

        <field name="popup_button_text" formElement="input">
            <settings>
                <label translate="true">Button Text</label>
                <dataScope>popup_button_text</dataScope>
            </settings>
        </field>

        <field name="popup_decline_text" formElement="input">
            <settings>
                <label translate="true">Decline Button Text</label>
                <dataScope>popup_decline_text</dataScope>
            </settings>
        </field>

        <field name="popup_close_text" formElement="input">
            <settings>
                <label translate="true">Close Button Text</label>
                <dataScope>popup_close_text</dataScope>
            </settings>
        </field>

        <field name="popup_terms_text" formElement="textarea">
            <settings>
                <label translate="true">Terms Text</label>
                <dataScope>popup_terms_text</dataScope>
            </settings>
        </field>

        <field name="is_wish_area_enabled" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="number">0</item>
                    <item name="prefer" xsi:type="string">toggle</item>
                    <item name="valueMap" xsi:type="array">
                        <item name="true" xsi:type="string">1</item>
                        <item name="false" xsi:type="string">0</item>
                    </item>
                </item>
            </argument>
            <settings>
                <label translate="true">Enable Wish Area</label>
                <dataScope>is_wish_area_enabled</dataScope>
                <dataType>boolean</dataType>
            </settings>
        </field>
    </fieldset>

    <fieldset name="cta_configuration" sortOrder="40">
        <settings>
            <label translate="true">CTA Configuration</label>
            <collapsible>true</collapsible>
        </settings>
        <field name="is_cta_enabled" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="number">0</item>
                    <item name="prefer" xsi:type="string">toggle</item>
                    <item name="valueMap" xsi:type="array">
                        <item name="true" xsi:type="string">1</item>
                        <item name="false" xsi:type="string">0</item>
                    </item>
                </item>
            </argument>
            <settings>
                <label translate="true">Is CTA Enabled</label>
                <dataScope>is_cta_enabled</dataScope>
                <dataType>boolean</dataType>
            </settings>
        </field>

        <field name="cta_image" formElement="imageUploader">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="visible" xsi:type="boolean">false</item>
                    <item name="imports" xsi:type="array">
                        <item name="visible" xsi:type="string">ns = ${ $.ns }, index = is_cta_enabled:checked</item>
                    </item>
                </item>
            </argument>
            <settings>
                <notice translate="true">Upload an image for the CTA popup (recommended size: 100x100px).</notice>
                <label translate="true">CTA Image</label>
                <componentType>imageUploader</componentType>
                <dataScope>cta_image</dataScope>
            </settings>
            <formElements>
                <imageUploader>
                    <settings>
                        <allowedExtensions>jpg jpeg gif png webp</allowedExtensions>
                        <maxFileSize>2097152</maxFileSize>
                        <uploaderConfig>
                            <param xsi:type="string" name="url">wishreward/wheel/upload</param>
                        </uploaderConfig>
                    </settings>
                </imageUploader>
            </formElements>
        </field>

        <field name="cta_label" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="visible" xsi:type="boolean">false</item>
                    <item name="imports" xsi:type="array">
                        <item name="visible" xsi:type="string">ns = ${ $.ns }, index = is_cta_enabled:checked</item>
                    </item>
                </item>
            </argument>
            <settings>
                <label translate="true">CTA Title</label>
                <dataScope>cta_label</dataScope>
            </settings>
        </field>

        <field name="cta_button_text" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="visible" xsi:type="boolean">false</item>
                    <item name="imports" xsi:type="array">
                        <item name="visible" xsi:type="string">ns = ${ $.ns }, index = is_cta_enabled:checked</item>
                    </item>
                </item>
            </argument>
            <settings>
                <label translate="true">CTA Button Text</label>
                <dataScope>cta_button_text</dataScope>
            </settings>
        </field>

        <field name="cta_position" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">bottom-right</item>
                    <item name="visible" xsi:type="boolean">false</item>
                    <item name="imports" xsi:type="array">
                        <item name="visible" xsi:type="string">ns = ${ $.ns }, index = is_cta_enabled:checked</item>
                    </item>
                    <item name="options" xsi:type="array">
                        <item name="top-left" xsi:type="array">
                            <item name="value" xsi:type="string">top-left</item>
                            <item name="label" xsi:type="string" translate="true">Top Left</item>
                        </item>
                        <item name="top-right" xsi:type="array">
                            <item name="value" xsi:type="string">top-right</item>
                            <item name="label" xsi:type="string" translate="true">Top Right</item>
                        </item>
                        <item name="bottom-left" xsi:type="array">
                            <item name="value" xsi:type="string">bottom-left</item>
                            <item name="label" xsi:type="string" translate="true">Bottom Left</item>
                        </item>
                        <item name="bottom-right" xsi:type="array">
                            <item name="value" xsi:type="string">bottom-right</item>
                            <item name="label" xsi:type="string" translate="true">Bottom Right</item>
                        </item>
                    </item>
                </item>
            </argument>
            <settings>
                <label translate="true">CTA Position</label>
                <dataScope>cta_position</dataScope>
            </settings>
        </field>

        <field name="cta_custom_css" formElement="textarea">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="visible" xsi:type="boolean">false</item>
                    <item name="imports" xsi:type="array">
                        <item name="visible" xsi:type="string">ns = ${ $.ns }, index = is_cta_enabled:checked</item>
                    </item>
                </item>
            </argument>
            <settings>
                <label translate="true">CTA Custom CSS</label>
                <dataScope>cta_custom_css</dataScope>
                <tooltip>
                    <description translate="true">Custom CSS to style the CTA popup (e.g., colors, sizes).</description>
                </tooltip>
            </settings>
        </field>
    </fieldset>

    <fieldset name="popup_trigger_configuration" sortOrder="50">
        <settings>
            <label translate="true">Popup Trigger Configuration</label>
            <collapsible>true</collapsible>
        </settings>

        <field name="is_scroll_enabled" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="number">0</item>
                    <item name="prefer" xsi:type="string">toggle</item>
                    <item name="valueMap" xsi:type="array">
                        <item name="true" xsi:type="string">1</item>
                        <item name="false" xsi:type="string">0</item>
                    </item>
                </item>
            </argument>
            <settings>
                <label translate="true">Enable Scroll Trigger</label>
                <dataScope>is_scroll_enabled</dataScope>
                <dataType>boolean</dataType>
            </settings>
        </field>

        <field name="scroll_percentage" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="visible" xsi:type="boolean">false</item>
                    <item name="default" xsi:type="number">50</item>
                    <item name="imports" xsi:type="array">
                        <item name="visible" xsi:type="string">ns = ${ $.ns }, index = is_scroll_enabled:checked</item>
                    </item>
                </item>
            </argument>
            <settings>
                <label translate="true">Scroll Percentage</label>
                <dataScope>scroll_percentage</dataScope>
                <dataType>number</dataType>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="50" xsi:type="array">
                                <item name="value" xsi:type="number">50</item>
                                <item name="label" xsi:type="string">50%</item>
                            </option>
                            <option name="75" xsi:type="array">
                                <item name="value" xsi:type="number">75</item>
                                <item name="label" xsi:type="string">75%</item>
                            </option>
                            <option name="100" xsi:type="array">
                                <item name="value" xsi:type="number">100</item>
                                <item name="label" xsi:type="string">100% (Bottom of Page)</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>

        <field name="is_timeout_enabled" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="number">0</item>
                    <item name="prefer" xsi:type="string">toggle</item>
                    <item name="valueMap" xsi:type="array">
                        <item name="true" xsi:type="string">1</item>
                        <item name="false" xsi:type="string">0</item>
                    </item>
                </item>
            </argument>
            <settings>
                <label translate="true">Enable Timeout Trigger</label>
                <dataScope>is_timeout_enabled</dataScope>
                <dataType>boolean</dataType>
            </settings>
        </field>

        <field name="timeout_duration" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="number">5000</item>
                    <item name="visible" xsi:type="boolean">false</item>
                    <item name="imports" xsi:type="array">
                        <item name="visible" xsi:type="string">ns = ${ $.ns }, index = is_timeout_enabled:checked</item>
                    </item>
                </item>
            </argument>
            <settings>
                <label translate="true">Timeout Duration (milliseconds)</label>
                <dataScope>timeout_duration</dataScope>
                <dataType>number</dataType>
                <validation>
                    <rule name="validate-number" xsi:type="boolean">true</rule>
                    <rule name="greater-than-equals-to" xsi:type="number">0</rule>
                </validation>
            </settings>
        </field>

        <field name="is_exit_enabled" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="number">0</item>
                    <item name="prefer" xsi:type="string">toggle</item>
                    <item name="valueMap" xsi:type="array">
                        <item name="true" xsi:type="string">1</item>
                        <item name="false" xsi:type="string">0</item>
                    </item>
                </item>
            </argument>
            <settings>
                <label translate="true">Enable Exit Intent Trigger</label>
                <dataScope>is_exit_enabled</dataScope>
                <dataType>boolean</dataType>
            </settings>
        </field>
    </fieldset>
</form>