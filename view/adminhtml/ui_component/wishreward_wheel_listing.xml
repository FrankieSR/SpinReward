<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <!-- 1) Общие настройки листинга -->
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <!-- Имя dataSource -->
            <item name="provider" xsi:type="string">wishreward_wheel_listing.wishreward_wheel_listing_data_source</item>
            <!-- Зависимости -->
            <item name="deps" xsi:type="string">wishreward_wheel_listing.wishreward_wheel_listing_data_source</item>
        </item>
    </argument>

    <settings>
        <!-- Спиннер при загрузке колонок -->
        <spinner>wheel_columns</spinner>
        <deps>
            <dep>wishreward_wheel_listing.wishreward_wheel_listing_data_source</dep>
        </deps>
        <!-- Кнопка «Add New Wheel» -->
        <buttons>
            <button name="add_new">
                <url path="wishreward/wheel/new"/>
                <class>primary</class>
                <label translate="true">Add New Wheel</label>
            </button>
        </buttons>
    </settings>

    <!-- 2) Data Source -->
    <dataSource name="wishreward_wheel_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <!-- Поле, по которому идентифицируются записи -->
                <param name="indexField" xsi:type="string">wheel_id</param>
            </storageConfig>
            <!-- URL для AJAX-обновления -->
            <updateUrl path="mui/index/render"/>
        </settings>
        <!-- ACL-ресурс, контролирующий доступ к гриду -->
        <aclResource>Doroshko_WishReward::wheels</aclResource>
        <!-- DataProvider, который возвращает коллекцию Wheel -->
        <dataProvider class="Doroshko\WishReward\Model\Wheel\DataProvider" name="wishreward_wheel_listing_data_source">
            <settings>
                <requestFieldName>wheel_id</requestFieldName>
                <primaryFieldName>wheel_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <!-- 3) Верхняя панель инструментов: массовые действия, пагинация и т.д. -->
    <listingToolbar name="listing_top">
        <massaction name="listing_massaction">
            <settings>
                <!-- Поле, по которому будут собираться ID для массового действия -->
                <indexField>wheel_id</indexField>
            </settings>
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Are you sure you want to delete selected wheels?</message>
                        <title translate="true">Delete Wheels</title>
                    </confirm>
                    <!-- Маршрут для MassDelete-экшена -->
                    <url path="wishreward/wheel/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>
            </action>
        </massaction>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>

    <!-- 4) Определение колонок -->
    <columns name="wheel_columns">
        <!-- Колонка для множественного выбора записей (selectionsColumn) -->
        <selectionsColumn name="ids" sortOrder="10">
            <settings>
                <indexField>wheel_id</indexField>
            </settings>
        </selectionsColumn>

        <!-- ID (wheel_id) -->
        <column name="wheel_id" sortOrder="50">
            <settings>
                <filter>textRange</filter>
                <dataType>number</dataType> <!-- Отображается как число -->
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>

        <!-- Title (title) -->
        <column name="title" sortOrder="60">
            <settings>
                <filter>text</filter>
                <dataType>text</dataType>
                <label translate="true">Title</label>
            </settings>
        </column>

        <!-- Active (is_active) -->
        <column name="is_active" sortOrder="70">
            <settings>
                <filter>select</filter>
                <dataType>select</dataType>
                <!-- Yes/No из core-сорса Magento -->
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <label translate="true">Active</label>
            </settings>
        </column>

        <!-- Start Date (start_date) -->
        <column name="start_date" sortOrder="80">
            <settings>
                <label translate="true">Start Date</label>
                <filter>dateRange</filter>
                <dataType>date</dataType> <!-- Отображаем как дату -->
                <sorting>asc</sorting>
            </settings>
        </column>

        <!-- End Date (end_date) -->
        <column name="end_date" sortOrder="90">
            <settings>
                <label translate="true">End Date</label>
                <filter>dateRange</filter>
                <dataType>date</dataType>
            </settings>
        </column>

        <!-- Actions (Edit, Delete, etc.) -->
        <actionsColumn name="actions" class="Doroshko\WishReward\Ui\Component\Listing\Column\Actions" sortOrder="100">
            <settings>
                <indexField>wheel_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
