<?php

/** @var \Doroshko\WishReward\Block\WheelPopup $block */
/** @var \Doroshko\WishReward\ViewModel\WheelPopupViewModel $wheelPopupViewModel */

$wheel = $block->getEligibleWheel();
if (!$wheel) {
    return;
}

$wheelPopupViewModel = $block->getData('viewModel');
$escaper   = $block->getEscaper();

$wheelPopupViewModel->setWheel($wheel);

$wheelId        = (int)$wheelPopupViewModel->getWheelId();
$ajaxUrl        = $escaper->escapeUrl($block->getUrl('wishreward/ajax/spinwheel'));
$wheelItems     = $wheelPopupViewModel->getWheelConfig() ? json_decode($wheelPopupViewModel->getWheelConfig(), true) : [];
$rotationDur    = $wheelPopupViewModel->getRotationDuration() ?: 6000;

$popupTitle         = $wheelPopupViewModel->getPopupTitle() ?: '';
$popupDesc          = $wheelPopupViewModel->getPopupDescription() ?: '';
$companyLogoPath    = $wheelPopupViewModel->getPopupCompanyLogo();
$companyText        = $wheelPopupViewModel->getPopupCompanyText();
$declineText        = $wheelPopupViewModel->getPopupDeclineText() ?: __('No, Thanks');
$privacyText        = $wheelPopupViewModel->getPopupTermsText() ?: __('I agree to the');
$buttonText         = $wheelPopupViewModel->getPopupButtonText() ?: __('Spin Now');

$wishEnabled        = $wheelPopupViewModel->getIsWishAreaEnabled();

$attemptsPerUser    = $wheelPopupViewModel->getAttemptsPerUser();
$attemptsPeriodUnit = $wheelPopupViewModel->getAttemptsPeriodUnit();

$winMessage         = $wheelPopupViewModel->getWinMessage() ?: __('Congratulations');
$noWinMessage       = $wheelPopupViewModel->getNoWinMessage() ?: __('Maybe next time');

$winMessage         = $wheelPopupViewModel->getWinMessage() ?: __('Congratulations');
$noWinMessage       = $wheelPopupViewModel->getNoWinMessage() ?: __('Maybe next time');
$isCustomerLoggedIn = $wheelPopupViewModel->isCustomerLoggedIn();
?>

<div class="wishreward" id="wishreward">
