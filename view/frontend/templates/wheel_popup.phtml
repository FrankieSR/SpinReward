                        aria-label="<?= $escaper->escapeHtmlAttr($buttonText) ?>">
                        <?= $escaper->escapeHtml($buttonText) ?>
                    </button>
                </form>

                <div class="wishreward__error">
                    <p class="wishreward__message-text wishreward__message-text--error"></p>
                </div>

                <div class="wishreward__opt-out">
                    <button
                        type="button"
                        id="wishreward-opt-out-link"
                        class="wishreward__button wishreward__button--opt-out"
                        aria-label="<?= $escaper->escapeHtmlAttr($declineText) ?>">
                        <?= $escaper->escapeHtml($declineText) ?>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div
        class="wishreward__result"
        id="wishreward-result"
        role="alert"
        aria-live="assertive"
        style="display: none;">
        <div
            id="wish-coupon-container"
            class="wishreward__coupon"
            style="display: none;"
            aria-hidden="true">
            <h2 class="wishreward__result-title">
                <?= $escaper->escapeHtml($winMessage) ?>
            </h2>
            <p class="wishreward__result-text wishreward__result-text--success" id="wish-result-text"></p>
