<?php

/** @var \Doroshko\WishReward\Block\CtaButton $block */
/** @var \Magento\Framework\Escaper $escaper */

$wheel = $block->getEligibleWheel();

if (!$wheel || !$wheel->getIsCtaEnabled()) {
    return;
}
$escaper = $block->getEscaper();
?>
<div class="wishreward-cta-wrapper <?= $escaper->escapeHtml($wheel->getCtaPosition()) ?>"
    style="<?= $escaper->escapeHtmlAttr($wheel->getCtaCustomCss()) ?>">
    <div class="wishreward-cta-inner">
        <?php if ($wheel->getCtaImage()): ?>
            <div class="wishreward-cta-image">
                <img src="<?= $escaper->escapeUrl($block->getMediaUrl($wheel->getCtaImage())) ?>"
                    alt="<?= $escaper->escapeHtmlAttr($wheel->getCtaLabel() ?: 'Promotion') ?>"
                    loading="lazy">
            </div>
        <?php endif; ?>

        <div class="wishreward-cta-content">
            <?php if ($wheel->getCtaLabel()): ?>
                <span class="wishreward-cta-label"><?= $escaper->escapeHtml($wheel->getCtaLabel()) ?></span>
            <?php endif; ?>

            <button class="wishreward-cta-button action primary"
                id="wishreward-cta-button"
                type="button"
                aria-label="<?= $escaper->escapeHtmlAttr($wheel->getCtaButtonText() ?: 'Join Now') ?>">
                <span><?= $escaper->escapeHtml($wheel->getCtaButtonText() ?: 'Join Now') ?></span>
            </button>
        </div>
    </div>
</div>

<script type="text/x-magento-init">
    {
    ".wishreward-cta-wrapper": {
        "Doroshko_WishReward/js/cta-button": {
            "ajaxUrl": "<?= $escaper->escapeJs($block->getAjaxUrl()) ?>",
            "wheelId": "<?= $escaper->escapeJs($wheel->getWheelId()) ?>"
        }
    }
}
</script>